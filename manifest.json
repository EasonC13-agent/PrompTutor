{
  "manifest_version": 3,
  "name": "PrompTutor",
  "key": "",
  "version": "0.1.0",
  "description": "Optionally share your AI chat logs with researchers for educational research.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "identity",
    "alarms"
  ],
  "oauth2": {
    "client_id": "731941445558-va0hugh0p0v6vtuoa11cm34nooqif3bs.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile"
    ]
  },
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://grok.com/*",
    "https://x.com/i/grok/*",
    "https://copilot.microsoft.com/*",
    "https://www.bing.com/chat/*",
    "https://chat.deepseek.com/*",
    "https://www.doubao.com/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://poe.com/*",
    "https://huggingface.co/chat/*"
  ],
  "background": {
    "service_worker": "src/background/index.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://grok.com/*",
        "https://x.com/i/grok/*",
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/chat/*",
        "https://chat.deepseek.com/*",
        "https://www.doubao.com/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://poe.com/*",
        "https://huggingface.co/chat/*"
      ],
      "js": [
        "src/content/dom-parser.js",
        "src/content/bridge.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://grok.com/*",
        "https://x.com/i/grok/*",
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/chat/*",
        "https://chat.deepseek.com/*",
        "https://www.doubao.com/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://poe.com/*",
        "https://huggingface.co/chat/*"
      ],
      "js": [
        "src/content/overlay.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://grok.com/*",
        "https://x.com/i/grok/*",
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/chat/*",
        "https://chat.deepseek.com/*",
        "https://www.doubao.com/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://poe.com/*",
        "https://huggingface.co/chat/*"
      ],
      "js": [
        "src/content/guidance.js",
        "src/content/detector.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/content/interceptor.js"
      ],
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://grok.com/*",
        "https://x.com/*",
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/*",
        "https://chat.deepseek.com/*",
        "https://www.doubao.com/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://poe.com/*",
        "https://huggingface.co/*"
      ]
    }
  ]
}
